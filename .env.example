# Canonical URL (production)
NEXT_PUBLIC_SITE_URL=https://www.lelavoir.re

# JSON-LD & structured data (E.164 recommended, e.g. +262XXXXXXXX)
NEXT_PUBLIC_BUSINESS_PHONE=

# Google Business Profile URL (optional) — added to JSON-LD sameAs for local SEO
NEXT_PUBLIC_GOOGLE_BUSINESS_URL=

# Mentions légales (affichées sur /mentions-legales, FR + EN)
NEXT_PUBLIC_LEGAL_COMPANY_NAME=
NEXT_PUBLIC_LEGAL_LEGAL_FORM=
NEXT_PUBLIC_LEGAL_SIRET=
NEXT_PUBLIC_LEGAL_PUBLICATION_DIRECTOR=
# Siège social (optionnel — défaut : adresse de la laverie)
NEXT_PUBLIC_LEGAL_REGISTERED_ADDRESS=

# Guest Wi‑Fi shown on /portail (omit both to hide credentials from the page)
NEXT_PUBLIC_WIFI_SSID=
NEXT_PUBLIC_WIFI_PASSWORD=

# Rate limiting /api/contact — créer une DB Redis Upstash gratuite (https://upstash.com/) puis coller l’URL REST + token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional — Instagram Basic Display API (server only). Used by /api/instagram for the homepage grid.
INSTAGRAM_ACCESS_TOKEN=

# Optional — Twitter/X Open Graph (e.g. @YourHandle)
NEXT_PUBLIC_TWITTER_SITE=
